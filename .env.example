# ──────────────────────────────────────────────────────────────
# Together / ASL-Connect — environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────

# ── Core ──
# Comma-separated list of allowed CORS origins (no "*" when credentials are used)
ALLOWED_ORIGINS=http://localhost:8000
# Set to "production" to enforce secure cookies / HSTS
APP_ENV=development
PORT=8000

# ── Database (PostgreSQL + pgvector) ──
# Example: postgresql+psycopg://together:together@localhost:5432/together
DATABASE_URL=postgresql+psycopg://together:together@localhost:5432/together

# ── Auth / JWT ──
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-generate-a-strong-random-secret
JWT_ALGORITHM=HS256
# 60 min access tokens keep sessions alive across normal usage gaps; refresh tokens
# silently extend that while keeping revocation possible (set lower once the async
# requireAuth flow is wired to the frontend page guard).
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Providers (LLM / TTS / STT) ──
# Selects which concrete adapter the provider abstraction uses (providers/).
#   LLM_PROVIDER: gemini | ollama
#   TTS_PROVIDER: gemini | pyttsx3
#   STT_PROVIDER: gemini | whisper
# Each primary is automatically backed by an offline fallback (Ollama / pyttsx3 /
# Whisper) so the app still works without a cloud key. Set *_FALLBACK=0 to disable.
LLM_PROVIDER=gemini
TTS_PROVIDER=gemini
STT_PROVIDER=gemini
LLM_FALLBACK=1
TTS_FALLBACK=1
STT_FALLBACK=1

# Local Whisper model size for the offline STT fallback (tiny|base|small|medium|large)
WHISPER_MODEL=base

# Google Gemini (current default — replace free-tier key with paid Google Cloud key)
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_STT_MODEL=gemini-2.5-flash

# Gemini TTS voice selection (prebuilt voices: Puck, Aoede, Schedar, Kore, Charon,
# Fenrir, Leda, Orus, Zephyr, Gacrux, Schedar, Sulafat, Umbriel, and ~15 more).
# Set per-language or a global default; all are optional (fallback order below).
#   Per-language env var → GEMINI_TTS_VOICE (global) → hardcoded default
GEMINI_TTS_VOICE=            # global default if no per-language match
GEMINI_TTS_VOICE_EN=Puck     # English (ASL users) — natural male voice
GEMINI_TTS_VOICE_AR=Schedar  # Arabic / Modern Standard
GEMINI_TTS_VOICE_EG=Schedar  # Egyptian Arabic dialect

# Optional cloud alternatives (leave blank to disable)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Offline fallback chain ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Inference tuning (Phase 5) ──
# INT8 dynamic quantization for the PyTorch Arabic predictor on CPU (1=on, 0=off)
TORCH_INT8=1
# TFLite CPU threads for ASL inference (0 = auto: min(4, cores))
TFLITE_NUM_THREADS=0

# ── Phone verification at signup via WhatsApp (WASender API) ──
# Set WASENDER_API_KEY to ENABLE phone verification; leave blank to disable
# (signup then works without a code). Get the key from the WASender dashboard
# (wasenderapi.com) after connecting your WhatsApp number to a session.
WASENDER_API_KEY=
# Optional overrides:
WASENDER_API_URL=https://www.wasenderapi.com/api/send-message
OTP_TTL_SECONDS=300
OTP_MESSAGE=Your Together verification code is {code}. It expires in 5 minutes.

# ── Live meeting TURN relay (Cloudflare Calls) ─────────────────
# Without TURN, two peers behind symmetric NAT (phone↔laptop on different
# networks) cannot connect. Create a TURN key in the Cloudflare dashboard
# (Calls → TURN) and set BOTH values; /api/webrtc-config then mints
# short-lived credentials for the browser (the API token itself is never
# sent to clients). Leave blank to fall back to public STUN only.
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
# Lifetime of each minted TURN credential, seconds (default 24h):
TURN_TTL_SECONDS=86400

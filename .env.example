# ──────────────────────────────────────────────────────────────
# Together / ASL-Connect — environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────

# ── Core ──
# Comma-separated list of allowed CORS origins (no "*" when credentials are used)
ALLOWED_ORIGINS=http://localhost:8000
# Set to "production" to enforce secure cookies / HSTS
APP_ENV=development
PORT=8000

# ── Database (PostgreSQL + pgvector) ──
# Example: postgresql+psycopg://together:together@localhost:5432/together
DATABASE_URL=postgresql+psycopg://together:together@localhost:5432/together

# ── Auth / JWT ──
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-generate-a-strong-random-secret
JWT_ALGORITHM=HS256
# 60 min access tokens keep sessions alive across normal usage gaps; refresh tokens
# silently extend that while keeping revocation possible (set lower once the async
# requireAuth flow is wired to the frontend page guard).
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Providers (LLM / TTS / STT) ──
# Selects which concrete adapter the provider abstraction uses.
# Options (planned): gemini | openai | anthropic | ollama (LLM); gemini | pyttsx3 (TTS); gemini | whisper (STT)
LLM_PROVIDER=gemini
TTS_PROVIDER=gemini
STT_PROVIDER=gemini

# Google Gemini (current default — replace free-tier key with paid Google Cloud key)
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_STT_MODEL=gemini-2.5-flash

# Optional cloud alternatives (leave blank to disable)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Offline fallback chain ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
